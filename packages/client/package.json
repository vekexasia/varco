{
  "name": "@varco/client",
  "version": "0.4.0",
  "description": "Browser client for scoped Home Assistant access through Varco.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": "./dist/varco-client.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vekexasia/varco.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/vekexasia/varco/issues"
  },
  "homepage": "https://vekexasia.github.io/varco/reference/client-api/",
  "keywords": [
    "home-assistant",
    "varco",
    "dashboard",
    "relay",
    "webrtc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --format=esm --outfile=dist/varco-client.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0"
  }
}
