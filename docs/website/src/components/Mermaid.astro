---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<pre class="varco-mermaid">{chart}</pre>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: false,
    securityLevel: "strict",
    theme: "base",
    themeVariables: {
      background: "#fbf7ef",
      primaryColor: "#f7fffd",
      primaryTextColor: "#0b2a44",
      primaryBorderColor: "#0b2a44",
      lineColor: "#0b2a44",
      secondaryColor: "#e7f8f6",
      tertiaryColor: "#ffffff",
      fontFamily: "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
      nodeBorder: "#0b2a44",
      clusterBkg: "#fbf7ef",
      clusterBorder: "#009aa6",
      edgeLabelBackground: "#fbf7ef",
    },
    flowchart: {
      curve: "basis",
      htmlLabels: true,
      padding: 16,
    },
  });

  async function renderMermaid() {
    const blocks = document.querySelectorAll<HTMLPreElement>("pre.varco-mermaid:not([data-rendered])");
    for (const block of blocks) {
      block.dataset.rendered = "true";
      const chart = block.textContent ?? "";
      const id = `varco-mermaid-${Math.random().toString(36).slice(2)}`;
      try {
        const { svg } = await mermaid.render(id, chart);
        const wrapper = document.createElement("div");
        wrapper.className = "varco-mermaid-rendered";
        wrapper.innerHTML = svg;
        block.replaceWith(wrapper);
      } catch (error) {
        block.dataset.rendered = "error";
        block.textContent = `Mermaid render error:\n${error instanceof Error ? error.message : String(error)}\n\n${chart}`;
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderMermaid, { once: true });
  } else {
    renderMermaid();
  }

  document.addEventListener("astro:page-load", renderMermaid);
</script>

<style is:global>
  .varco-mermaid-rendered {
    margin: 1.5rem 0 2rem;
    padding: 1rem;
    overflow-x: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: #fbf7ef;
  }

  .varco-mermaid-rendered svg {
    display: block;
    width: 100%;
    min-width: 760px;
    height: auto;
  }

  .varco-mermaid-rendered .node rect,
  .varco-mermaid-rendered .node polygon,
  .varco-mermaid-rendered .node circle,
  .varco-mermaid-rendered .node ellipse {
    filter: drop-shadow(0 8px 10px rgb(8 35 58 / 0.08));
  }
</style>
